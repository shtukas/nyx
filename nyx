#!/usr/bin/ruby

# encoding: UTF-8

require_relative "Libs/loader.rb"

# ----------------------------------------------------------------------------

def mainLoop()
    loop {
        operations = ["search", "insert new entity", "data sources listing and dive", "node taxonomy listing and dive", "generate unique-string", "fsck"]
        operation = LucilleCore::selectEntityFromListOfEntitiesOrNull("operation", operations)
        return if operation.nil?
        if operation == "search" then
            Search::searchLoop()
        end
        if operation == "insert new entity" then
            entity = NxEntitiesinteractivelyCreateNewEntityOrNull()
            exit if entity.nil?
            NxEntitieslanding(entity)
        end
        if operation == "data sources listing and dive" then
            loop {
                types = ["NxAsteroid", "NxDirectory2", "NxUniqueString"]
                type = LucilleCore::selectEntityFromListOfEntitiesOrNull("type:", types)
                break if type.nil?
                if type == "NxAsteroid" then
                    NxEntitiesentitiesDive(NxAsteroid::nx45s())
                end
                if type == "NxDirectory2" then
                    NxEntitiesentitiesDive(NxDirectory2::directories())
                end
                if type == "NxUniqueString" then
                    NxEntitiesentitiesDive(NxUniqueString::nx27s())
                end
            }
        end
        if operation == "node taxonomy listing and dive" then
            loop {
                taxonomy = NodeTaxonomy::selectNodeTaxonomyOrNull()
                break if taxonomy.nil?
                nodes = NxNode::nx10s().select{|node| node["taxonomy"] == taxonomy }
                NxEntitiesentitiesDive(nodes)
            }
        end
        if operation == "generate unique-string" then
            puts SecureRandom.hex(6)
            LucilleCore::pressEnterToContinue()
        end
        if operation == "fsck" then
            Fsck::fsckEntities()
        end
    }
end

mainLoop()
