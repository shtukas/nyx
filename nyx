#!/usr/bin/ruby

# encoding: UTF-8

require_relative "Libs/loader.rb"

# ----------------------------------------------------------------------------

def mainLoop()
    loop {
        operations = ["search", "insert new entity", "entity data types listing and dive", "entity classification types listing and dive", "generate unique-string", "fsck"]
        operation = LucilleCore::selectEntityFromListOfEntitiesOrNull("operation", operations)
        return if operation.nil?
        if operation == "search" then
            Search::searchLoop()
        end
        if operation == "insert new entity" then
            entity = NxEntity::interactivelyCreateNewEntityOrNull()
            exit if entity.nil?
            NxEntity::landing(entity)
        end
        if operation == "entity data types listing and dive" then
            loop {
                types = ["NxAsteroid", "NxDirectory2", "NxEvent", "NxTimelinePoint", "NxUniqueString"]
                type = LucilleCore::selectEntityFromListOfEntitiesOrNull("type:", types)
                break if type.nil?
                if type == "NxAsteroid" then
                    NxEntity::entitiesDive(NxAsteroid::nx45s())
                end
                if type == "NxDirectory2" then
                    NxEntity::entitiesDive(NxDirectory2::directories())
                end
                if type == "NxEvent" then
                    NxEntity::entitiesDive(NxEvent::events())
                end
                if type == "NxTimelinePoint" then
                    NxEntity::entitiesDive(NxTimelinePoint::points())
                end
                if type == "NxUniqueString" then
                    NxEntity::entitiesDive(NxUniqueString::nx27s())
                end
            }
        end
        if operation == "entity classification types listing and dive" then
            loop {
                types = ["NxListing", "NxNode", "NxTag"]
                type = LucilleCore::selectEntityFromListOfEntitiesOrNull("type:", types)
                break if type.nil?
                if type == "NxListing" then
                    NxEntity::entitiesDive(NxListing::nxListings())
                end
                if type == "NxNode" then
                    NxEntity::entitiesDive(NxNode::nx10s())
                end
                if type == "NxTag" then
                    NxEntity::entitiesDive(NxTag::nxTags())
                end
            }
        end
        if operation == "generate unique-string" then
            puts SecureRandom.hex(6)
            LucilleCore::pressEnterToContinue()
        end
        if operation == "fsck" then
            Fsck::fsckEntities()
        end
    }
end

mainLoop()
