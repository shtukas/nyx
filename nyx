#!/usr/bin/ruby

# encoding: UTF-8

require_relative "Libs/loader.rb"

# ----------------------------------------------------------------------------

def mainLoop()
    loop {
        operations = ["search", "insert new entity", "data pointers listing and dive", "node types listing and dive", "generate unique-string", "fsck"]
        operation = LucilleCore::selectEntityFromListOfEntitiesOrNull("operation", operations)
        return if operation.nil?
        if operation == "search" then
            Search::searchLoop()
        end
        if operation == "insert new entity" then
            entity = NxEntity::interactivelyCreateNewEntityOrNull()
            exit if entity.nil?
            NxEntity::landing(entity)
        end
        if operation == "data pointers listing and dive" then
            loop {
                types = ["NxAsteroid", "NxDirectory2", "NxUniqueString"]
                type = LucilleCore::selectEntityFromListOfEntitiesOrNull("type:", types)
                break if type.nil?
                if type == "NxAsteroid" then
                    NxEntity::entitiesDive(NxAsteroid::nx45s())
                end
                if type == "NxDirectory2" then
                    NxEntity::entitiesDive(NxDirectory2::directories())
                end
                if type == "NxUniqueString" then
                    NxEntity::entitiesDive(NxUniqueString::nx27s())
                end
            }
        end
        if operation == "node types listing and dive" then
            loop {
                nodeType = NxNodeTypes::selectNodeTypeOrNull()
                break if nodeType.nil?
                nodes = NxNode::nx10s().select{|node| node["nodeType"] == nodeType }
                NxEntity::entitiesDive(nodes)
            }
        end
        if operation == "generate unique-string" then
            puts SecureRandom.hex(6)
            LucilleCore::pressEnterToContinue()
        end
        if operation == "fsck" then
            Fsck::fsckEntities()
        end
    }
end

mainLoop()
